{
  "name": "esencia-belleza",
  "version": "1.0.0",
  "description": "E-commerce Esencia de Belleza — Next.js + Supabase + Stripe",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "scrape": "ts-node --project tsconfig.scripts.json scraper.ts",
    "import": "ts-node --project tsconfig.scripts.json -r dotenv/config scripts/import-catalogo.ts",
    "import:woo": "ts-node --project tsconfig.scripts.json scripts/import-woo.ts",
    "import:woo:nuevos": "ts-node --project tsconfig.scripts.json scripts/import-woo.ts --solo-nuevos",
    "seo:batch": "ts-node --project tsconfig.scripts.json scripts/seo-batch.ts",
    "seo:batch:todos": "ts-node --project tsconfig.scripts.json scripts/seo-batch.ts --todos",
    "upload:logos": "ts-node --project tsconfig.scripts.json scripts/upload-logos.ts"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.108.2",
    "next": "^14.2.35",
    "playwright": "^1.44.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^15.12.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.15",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
